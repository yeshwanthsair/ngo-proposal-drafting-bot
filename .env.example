# Copy this file to .env and fill in your values
# NEVER commit .env to Git

# ── Ollama (runs locally, 100% free, no API keys) ────────────────────
# Download from: https://ollama.com/download
# Then run: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── Groq (cloud LLM, free tier) ──────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── ChromaDB settings ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Admin settings ────────────────────────────────────────────────────
ADMIN_PASSWORD=Yeshwanth@2006

# ── Email (for admin access requests) ────────────────────────────────
# Use a Gmail account + App Password (NOT your real password)
# How to get App Password: https://myaccount.google.com/apppasswords
SENDER_EMAIL=your_gmail@gmail.com
SENDER_PASSWORD=your_gmail_app_password

# ── App settings ──────────────────────────────────────────────────────
APP_TITLE=NGO Proposal Drafting Bot
DEBUG=True
